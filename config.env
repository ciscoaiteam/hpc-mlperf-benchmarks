#!/usr/bin/env bash
# =============================================================================
# MLPerf Training Benchmark Configuration
# Source this file in all run scripts: source config.env
# =============================================================================

# ---------------------------------------------------------------------------
# Paths
# ---------------------------------------------------------------------------
SCRATCH_DIR="/opt/mlperf"
MLPERF_TRAINING_DIR="${SCRATCH_DIR}/mlperf_training"
DATA_DIR="${SCRATCH_DIR}/data"
MODELS_DIR="${SCRATCH_DIR}/models"
RESULTS_DIR="${SCRATCH_DIR}/results"
LOG_DIR="${SCRATCH_DIR}/logs"

# ---------------------------------------------------------------------------
# Benchmark run parameters (MLPerf closed division)
# ---------------------------------------------------------------------------
NUM_RUNS=1                     # Total runs per config (set to 10 for full submission)
GPU_CONFIGS=(4)                # 845A MGX: 4 GPUs per node; 8-GPU via 2-node multi-node run

# ---------------------------------------------------------------------------
# Llama 3.1 8B Pre-Training (C4/en/3.0.1) — MLPerf small_llm_pretraining
# ---------------------------------------------------------------------------
LLAMA31_TARGET_LOG_PPL=3.3         # Target: validation log perplexity ≤ 3.3
C4_PREPROCESSED_DIR="${SCRATCH_DIR}/llama31-c4-preprocessed"
LLAMA31_TOKENIZER_DIR="${SCRATCH_DIR}/llama31-tokenizer"
LLAMA31_NPY_INDEX_DIR="${SCRATCH_DIR}/llama31-npy-index"   # Megatron index cache (>400 GB needed)
LLAMA31_RESULT_DIR="${RESULTS_DIR}/llama31_pretraining"
LLAMA31_LOG_DIR="${LOG_DIR}/llama31_pretraining"
LLAMA31_SRC_SUBDIR="small_llm_pretraining/nemo"
# Docker image built from Dockerfile.h200 in MLCommons repo
LLAMA31_IMAGE="mlperf-llama31-pretraining:h200"
# H200 hyperparameters (from config_H200_1x8x1_8b.sh in MLCommons repo)
LLAMA31_GBS=512                    # Global batch size (sequences)
LLAMA31_MBS=2                      # Micro batch size per GPU
LLAMA31_MAX_LR="8e-3"              # Peak learning rate (linear scaled: 5e-4 × 512/32)
LLAMA31_WARMUP_STEPS=32            # = 16384 // GBS
LLAMA31_EVAL_EVERY=12288           # Evaluate every N training sequences

# ---------------------------------------------------------------------------
# LLM Fine-Tuning (Llama 2 70B on SCROLLS GovReport)
# ---------------------------------------------------------------------------
LLM_TARGET_LOSS=0.925          # Target: 0.925 cross-entropy loss
LLAMA2_MODEL_DIR="${SCRATCH_DIR}/llama2-70b/Llama2-70b-fused-qkv-mlperf"
GOVREPORT_DATA_DIR="${SCRATCH_DIR}/govreport"
LLM_RESULT_DIR="${RESULTS_DIR}/llm_finetuning"
LLM_LOG_DIR="${LOG_DIR}/llm_finetuning"
LLM_SRC_SUBDIR="llama2_70b_lora"
# Docker image (built from MLCommons repo)
LLM_IMAGE="mlperf-llm-finetuning:h200"

# ---------------------------------------------------------------------------
# H200 NVL NCCL / performance tuning — Cisco UCS 845A MGX (PCIe topology)
# Topology: RoCEv2 over Cisco Nexus 400G (6 mlx5 NICs/node on <GPU_FABRIC_SUBNET>.x)
#   mlx5_0 (ens10f0np0)  → PIX to GPU2+3, NODE to GPU0+1
#   mlx5_1 (ens32f0np0)  → PIX to GPU0+1, NODE to GPU2+3
#   mlx5_4/5             → SYS to all GPUs (far — avoid for training traffic)
# No NVLink between GPUs (PCIe only). Use IB/RoCE for all inter-GPU comms.
# ---------------------------------------------------------------------------
export NCCL_SOCKET_IFNAME=ens10f0np0
export NCCL_IB_DISABLE=0
export NCCL_IB_HCA=mlx5_0,mlx5_1
export NCCL_DEBUG=INFO   # confirm IB selected, revert to WARN after first run
export CUDA_DEVICE_MAX_CONNECTIONS=1
# NVLS=0: no NVSwitch on 845A MGX
export NCCL_NVLS_ENABLE=0
# P2P_LEVEL=SYS: allow PCIe P2P across all topology levels (no NVLink on 845A)
export NCCL_P2P_LEVEL=SYS

# ---------------------------------------------------------------------------
# Multi-node rendezvous (overridden by multinode launcher)
# ---------------------------------------------------------------------------
MLPERF_MASTER_ADDR="<NODE_MGMT_IP>"   # c845-1 (matches NCCL_SOCKET_IFNAME)
MLPERF_MASTER_PORT="29500"

# ---------------------------------------------------------------------------
# Docker shared memory & GPU access
# ---------------------------------------------------------------------------
DOCKER_SHM_SIZE="64g"
DOCKER_COMMON_ARGS="--gpus all --shm-size=${DOCKER_SHM_SIZE} --ulimit memlock=-1 --ulimit stack=67108864"
DOCKER_CMD="docker"

# ---------------------------------------------------------------------------
# CPU/NUMA affinity — 845A MGX H200 NVL topology (from nvidia-smi topo)
#   2 NUMA nodes (socket 0 and socket 1), all 4 GPUs on NUMA node 0
#   NUMA node 0 CPUs: 0-63, 128-191  (socket 0 physical + HT siblings)
#   NUMA node 1 CPUs: 64-127, 192-255 (socket 1 — no GPUs attached)
#   GPU 0 → NUMA 0  (PIX to GPU1 via same PCIe bridge)
#   GPU 1 → NUMA 0  (PIX to GPU0 via same PCIe bridge)
#   GPU 2 → NUMA 0  (PIX to GPU3 via same PCIe bridge)
#   GPU 3 → NUMA 0  (PIX to GPU2 via same PCIe bridge)
#   No NVLink between GPUs — PCIe only (PIX within pairs, NODE across pairs)
# ---------------------------------------------------------------------------
ALL_CPUS="0-63,128-191"   # NUMA0 only — all GPUs are on socket 0

declare -A GPU_CPUS=(
    [0]="0-63,128-191"   [1]="0-63,128-191"
    [2]="0-63,128-191"   [3]="0-63,128-191"
)

# get_numa_args <gpu_id_string>
# Returns Docker --cpuset-cpus flag for a given GPU set.
# gpu_id_string: comma-separated GPU indices, e.g. "0,1,2,3"
get_numa_args() {
    local GPU_IDS_STR="$1"
    local NUM_GPUS
    NUM_GPUS=$(echo "${GPU_IDS_STR}" | tr ',' '\n' | wc -l)

    if [[ "${NUM_GPUS}" -ge 4 ]]; then
        echo "--cpuset-cpus=${ALL_CPUS}"
        return
    fi

    local CPU_RANGES=()
    for gpu in ${GPU_IDS_STR//,/ }; do
        CPU_RANGES+=("${GPU_CPUS[$gpu]}")
    done
    local CPUSET
    CPUSET=$(IFS=','; echo "${CPU_RANGES[*]}")
    echo "--cpuset-cpus=${CPUSET}"
}

# ---------------------------------------------------------------------------
# GPU idle check — call before any benchmark run
# Usage: check_gpus_idle [required_free_gpu_count]
# ---------------------------------------------------------------------------
check_gpus_idle() {
    local REQUIRED_FREE="${1:-1}"

    echo "[$(date '+%Y-%m-%d %H:%M:%S')] Checking GPU utilization via nvidia-smi..."

    # List any PIDs currently using GPU compute resources
    local COMPUTE_PROCS
    COMPUTE_PROCS=$(nvidia-smi --query-compute-apps=pid,used_memory,name \
                               --format=csv,noheader 2>/dev/null)

    if [[ -n "${COMPUTE_PROCS}" ]]; then
        echo "=========================================================="
        echo "  ERROR: GPU(s) are in use by running processes:"
        echo "----------------------------------------------------------"
        echo "  PID        | VRAM Used | Process Name"
        echo "----------------------------------------------------------"
        echo "${COMPUTE_PROCS}" | while IFS=',' read -r pid mem name; do
            printf "  %-10s | %-9s | %s\n" "${pid// /}" "${mem// /}" "${name// /}"
        done
        echo "=========================================================="
        echo "  Terminate the above processes before running benchmarks."
        echo "  Or run:  sudo kill -9 <PID>"
        return 1
    fi

    # Secondary check: per-GPU memory usage (catches zombie allocations)
    local FAILED_GPUS=()
    while IFS=',' read -r idx mem_used mem_total; do
        idx="${idx// /}"; mem_used="${mem_used// /}"; mem_total="${mem_total// /}"
        # Flag any GPU with >512 MiB already allocated (driver overhead is ~200 MiB)
        local MEM_MB
        MEM_MB=$(echo "${mem_used}" | grep -oE '[0-9]+')
        if [[ "${MEM_MB}" -gt 512 ]]; then
            FAILED_GPUS+=("GPU ${idx}: ${mem_used} / ${mem_total} in use")
        fi
    done < <(nvidia-smi --query-gpu=index,memory.used,memory.total \
                        --format=csv,noheader 2>/dev/null)

    if [[ ${#FAILED_GPUS[@]} -gt 0 ]]; then
        echo "=========================================================="
        echo "  ERROR: Elevated GPU memory detected (possible zombie alloc):"
        for entry in "${FAILED_GPUS[@]}"; do
            echo "    ${entry}"
        done
        echo "=========================================================="
        return 1
    fi

    # Report clean state
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] All GPUs idle — proceeding."
    nvidia-smi --query-gpu=index,name,memory.used,memory.total,utilization.gpu \
               --format=csv,noheader | \
        awk -F',' '{printf "  GPU %-2s %-20s  mem: %-12s / %-12s  util: %s\n",
                   $1,$2,$3,$4,$5}'
    return 0
}

# AMD MI350X — Shared Configuration
# Source this file in all run scripts: source config.env

# ── Hardware ──────────────────────────────────────────────────────────────
export NODE1_MGMT="198.18.130.0"
export NODE2_MGMT="198.18.130.10"
export NODE1_FABRIC="192.168.200.11"    # 400G ionic NIC (primary)
export NODE2_FABRIC="192.168.200.21"    # 400G ionic NIC (primary)
export GPUS_PER_NODE=8

# ── Data paths (on server) ─────────────────────────────────────────────────
export MLPERF_DIR="/opt/mlperf"
export C4_PREPROCESSED_DIR="${MLPERF_DIR}/llama31-c4-preprocessed"
export LLAMA31_TOKENIZER_DIR="${MLPERF_DIR}/llama31-tokenizer"
export GOVREPORT_DIR="${MLPERF_DIR}/govreport"
export LLAMA2_MODEL_DIR="${MLPERF_DIR}/models/llama2-70b"
export LOG_DIR="${MLPERF_DIR}/logs"
export RESULTS_DIR="${MLPERF_DIR}/results"

# ── Container images ────────────────────────────────────────────────────────
export PRETRAIN_IMAGE="rocm/amd-mlperf:llama31_8b_training_6.0"
export FINETUNE_IMAGE="rocm/amd-mlperf:llama2_70b_training_6.0"

# ── RCCL / Network ─────────────────────────────────────────────────────────
# Using socket transport over 400G ionic NICs (RDMA not yet configured)
export RCCL_SOCKET_IFNAME="enp86s0"          # Primary 400G NIC (192.168.200.11/21)
export NCCL_SOCKET_IFNAME="enp86s0"
export NCCL_DEBUG="WARN"
export NCCL_IB_DISABLE=1                     # No IB/RDMA currently active
export MIOPEN_USER_DB_PATH="/tmp/miopen_cache"

# ── GPU arch ────────────────────────────────────────────────────────────────
export HIP_VISIBLE_DEVICES_ALL="0,1,2,3,4,5,6,7"
export ROCR_VISIBLE_DEVICES_ALL="0,1,2,3,4,5,6,7"

# ── MLPerf Llama 3.1 8B Pretraining ───────────────────────────────────────
export GLOBAL_BATCH_SIZE=2048
export MICRO_BATCH_SIZE=1
export TARGET_LOG_PPL=3.3
export MAX_STEPS=20000                       # Will stop early on convergence

# ── MLPerf Llama 2 70B Fine-Tuning ────────────────────────────────────────
export FT_LR="4e-4"
export FT_TARGET_LOSS=0.925
export FT_MAX_STEPS=1024
export FT_LORA_RANK=16
export FT_LORA_ALPHA=32
